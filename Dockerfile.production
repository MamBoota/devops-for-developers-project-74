FROM node:20

WORKDIR /app

# Копируем файлы зависимостей для эффективного кеширования слоёв
COPY app/package*.json ./

# Чистая установка зависимостей
RUN npm ci

# Копируем исходный код приложения
COPY app/ .

# Открываем порт
EXPOSE 8080

# Сборка приложения (если требуется)
RUN make build

# Команда запуска по умолчанию
CMD ["make", "start"]